# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/rice-mill
DB_SSL=false
DB_SSL_VALIDATE=true
DB_POOL_SIZE=10
DB_AUTH_SOURCE=admin

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
JWT_ISSUER=rice-mill-api
JWT_AUDIENCE=rice-mill-client

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,https://yourdomain.com

# Security Configuration
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME=2h
PASSWORD_RESET_EXPIRE=10m

# Rate Limiting Configuration (In-memory)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@ricemill.com

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Session Configuration
SESSION_SECRET=your-session-secret-change-this
SESSION_MAX_AGE=86400000

# Database Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=backups/

# SSL Configuration (for production)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Performance Configuration
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
CLUSTER_ENABLED=false
CLUSTER_WORKERS=0

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# Security Headers
HELMET_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true

# Feature Flags
TWO_FACTOR_AUTH_ENABLED=false
API_KEY_AUTH_ENABLED=false
WEBHOOK_ENABLED=false

# Development Only
DEBUG=app:*
MOCK_EMAIL=true
